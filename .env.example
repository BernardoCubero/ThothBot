# Claves de API de servicios externos
GEOAPIFY_API_KEY=tu_clave_de_geoapify_aqui
TKMASTER=tu_clave_de_ticketmaster_aqui

# Configuración de MariaDB (Persistencia de Usuarios)
MARIADB_USER=root
MARIADB_PASSWORD=tu_contraseña_aqui
MARIADB_HOST=localhost
MARIADB_PORT=3306
MARIADB_DB=thothbot_db

# Configuración de MongoDB (Logs de Conversación)
# Nota: Actualmente se usa localhost:27017 por defecto en mongo_logger.py
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DB=thothbot

# Configuración de Telegram (Próximamente para despliegue)
TELEGRAM_TOKEN=tu_token_de_bot_father_aqui
TELEGRAM_VERIFY=thothbot_verify
